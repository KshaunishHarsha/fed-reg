---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- Login overlay — hidden until auth check runs -->
<div id="login-overlay" style="display:none">
  <div class="login-card">
    <div class="login-logos">
      <img src="/openpawslogo.png" alt="OpenPaws Logo" />
    </div>
    <p class="login-title">Federal Register Sentinel</p>
    <p class="login-sub">Demo environment · sign in to continue</p>
    <form id="login-form" novalidate>
      <input id="pw-input" type="password" placeholder="Password" autocomplete="current-password" />
      <button type="submit" class="btn btn-teal" style="width:100%;justify-content:center;margin-top:4px;">Sign in</button>
      <p id="login-err" class="status-msg err" style="text-align:center;"></p>
    </form>
  </div>
</div>

<main>

  <!-- NAV -->
  <nav style="align-items: flex-start;">
    <span class="brand" style="margin-top: 6px;">Open<span>Paws</span> · Federal Register Sentinel</span>
    <div style="display: flex; flex-direction: column; gap: 8px; align-items: flex-end;">
      <span class="label">DEMO ENVIRONMENT</span>
      <span style="font-size: 12px; font-weight: 500; color: var(--grey); max-width: 320px; text-align: right; line-height: 1.4;">
        This frontend is a standalone demo. Production deployment will integrate directly into the existing Open Paws platform and authentication infrastructure.
      </span>
    </div>
  </nav>

  <!-- INTRO -->
  <section class="intro" style="text-align: center;">
    <div style="display: flex; justify-content: center; align-items: center; margin-bottom: 32px;">
      <img src="/openpawslogo.png" alt="OpenPaws Logo" style="height: 70px; object-fit: contain;" />
    </div>
    <p class="kicker">Animal Legal Defense Fund</p>
    <h1>Daily regulatory intelligence,<br /><em>automated.</em></h1>
    <p class="lead" style="margin: 0 auto;">The Federal Register publishes hundreds of documents daily. This pipeline finds the ones that matter to animal law and emails your team a plain-language digest every morning.</p>
  </section>

  <!-- SUBSCRIBE + LIST -->
  <section class="two-col">

    <!-- Left: subscribe form + run button -->
    <div class="panel">
      <p class="panel-label">Subscribe</p>
      <p class="panel-sub">Receive the daily digest when animal-relevant regulations are published.</p>

      <form id="form" novalidate>
        <label for="email" class="sr-only">Email address</label>
        <input id="email" type="email" placeholder="you@aldf.org" autocomplete="email" required />

        <p style="margin: 14px 0 8px; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted);">Categories to receive</p>
        <div id="pref-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px 16px; margin-bottom: 14px;">
          <label class="pref-check"><input type="checkbox" name="pref_welfare"                checked /> Companion &amp; Gen. Welfare</label>
          <label class="pref-check"><input type="checkbox" name="pref_wildlife"               checked /> Wild Animals &amp; Habitat</label>
          <label class="pref-check"><input type="checkbox" name="pref_agriculture"            checked /> Livestock Regulations</label>
          <label class="pref-check"><input type="checkbox" name="pref_agricultural_subsidies" checked /> Farm Subsidies &amp; Loans</label>
          <label class="pref-check"><input type="checkbox" name="pref_research_animals"       checked /> Lab &amp; Research Animals</label>
          <label class="pref-check"><input type="checkbox" name="pref_marine"                 checked /> Marine &amp; Ocean Life</label>
          <label class="pref-check"><input type="checkbox" name="pref_trade"                  checked /> Animal Trade &amp; Export</label>
        </div>

        <button type="submit" id="sub-btn" class="btn btn-teal">Subscribe</button>
        <p id="sub-status" class="status-msg" role="alert" aria-live="polite"></p>
      </form>
      <p style="font-size: 13px; color: var(--muted); margin-top: 12px; line-height: 1.5;">
        <strong>Note:</strong> After subscribing, you must manually run the pipeline below for a specific date to receive an email. We recommend testing with <strong>June 1, 2026</strong> which contains confirmed documents.
      </p>


      <div class="divider"></div>

      <p class="panel-label">Run pipeline</p>
      <p class="panel-sub">Fetch today's Federal Register, filter, summarise, and send the digest to all subscribers.</p>
      <div class="demo-banner">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Demo only.</strong> In production, the pipeline runs automatically once per day with no manual trigger, sending one digest per day's Federal Register publications, delivered every morning.</span>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <input type="date" id="run-date" class="date-input" />
        <button id="run-btn" class="btn btn-outline">Send digest</button>
      </div>
      <p id="run-status" class="status-msg" role="alert" aria-live="polite"></p>
    </div>

    <!-- Right: live subscriber list -->
    <div class="panel">
      <div class="list-header" style="flex-direction: column; align-items: stretch; gap: 12px; margin-bottom: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
          <div>
            <p class="panel-label">Active subscribers</p>
            <p class="demo-note">Only visible in this demo — hidden in production</p>
          </div>
          <button id="refresh" class="icon-btn" aria-label="Refresh list">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          </button>
        </div>
        <p style="font-size: 13px; color: var(--text); line-height: 1.5; font-weight: 500; background: var(--soft); padding: 12px; border-radius: 6px; border: 1px solid var(--border);">
          Only one mail will be sent for a day. State is tracked to ensure no double mails are sent, but for this demo we have enabled a bypass allowing the same document to come again when hitting the same date for demo testing.
        </p>
      </div>

      <div id="list" class="sub-list">
        <div class="loading-dots"><span></span><span></span><span></span></div>
      </div>
      <p id="count" class="sub-count"></p>
    </div>

  </section>

  <!-- PIPELINE -->
  <section class="pipeline-section">
    <div class="pipeline-header">
      <p class="kicker">How it works</p>
      <h2>Three phases. Zero manual steps.</h2>
    </div>

    <div class="pipeline">
      <div class="step">
        <p class="step-num">01</p>
        <p class="step-title">Ingest & Filter</p>
        <p class="step-body">Pulls new publications daily from 7 federal agencies. A four-layer pipeline, consisting of an agency filter, keyword scoring, full-text PDF scan, and AI verification, narrows ~500 documents to the handful that are animal-relevant.</p>
      </div>
      <div class="arrow">→</div>
      <div class="step">
        <p class="step-num">02</p>
        <p class="step-title">Summarise</p>
        <p class="step-body">Each confirmed document is routed by page length and processed by GPT-4o-mini. Output includes a plain-language summary, advocacy relevance, suggested actions, and talking points, validated against a strict schema.</p>
      </div>
      <div class="arrow">→</div>
      <div class="step">
        <p class="step-num">03</p>
        <p class="step-title">Deliver</p>
        <p class="step-body">Summaries are compiled into a structured HTML digest sorted by urgency: proposed rules with open comment windows first, then final rules, then potential matches, and emailed to all subscribers.</p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <span>OpenPaws.ai · Built for the Animal Legal Defense Fund</span>
    <span>Summaries are AI-generated and informational only, not legal advice.</span>
  </footer>

</main>
</Layout>

<style is:global>
  /* ── Tokens ──────────────────────────────────── */
  :root {
    --black:  #000;
    --white:  #fff;
    --teal:   #006C67;
    --grey:   #555;
    --border: #e0e0e0;
    --soft:   #f7f7f7;
    --text:   #111;
    --muted:  #333;
    --coral:  #E85D04;
  }
  .sr-only { position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0); }

  /* ── Shell ───────────────────────────────────── */
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 28px 56px;
  }

  /* ── Nav ─────────────────────────────────────── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 44px;
  }
  .brand {
    font-family: 'DM Serif Display', serif;
    font-size: 17px;
    color: var(--black);
    letter-spacing: -0.01em;
  }
  .brand span { color: var(--teal); }
  .label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.15em;
    color: var(--teal);
    background: rgba(0, 108, 103, 0.05);
    border: 2px solid rgba(0, 108, 103, 0.2);
    padding: 4px 12px;
    border-radius: 6px;
  }

  /* ── Intro ───────────────────────────────────── */
  .intro { margin-bottom: 40px; }
  .kicker {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 12px;
    color: var(--grey);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 400;
    color: var(--black);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  h1 em { color: var(--teal); font-style: italic; }
  .lead {
    font-size: 15px;
    color: var(--muted);
    max-width: 580px;
    line-height: 1.65;
  }

  /* ── Two-col ─────────────────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 48px;
    align-items: start;
  }
  @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }

  .panel {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    background: var(--white);
  }
  .panel-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 4px;
  }
  .panel-sub {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 14px;
    line-height: 1.55;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .btn-teal  { background: var(--teal); color: #fff; }
  .btn-teal:hover:not(:disabled) { opacity: 0.85; }
  .btn-outline {
    background: var(--white);
    color: var(--black);
    border: 1px solid var(--border);
  }
  .btn-outline:hover:not(:disabled) { border-color: #aaa; background: var(--soft); }
  .btn-outline.loading { color: var(--grey); }

  /* Form */
  #form { margin-bottom: 0; }
  input[type="email"] {
    width: 100%;
    padding: 9px 13px;
    border: 1px solid var(--border);
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: var(--black);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
    margin-bottom: 10px;
    display: block;
  }
  input[type="email"]::placeholder { color: #c0c0c0; }
  input[type="email"]:focus { border-color: var(--teal); }

  .date-input {
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: var(--black);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
  }
  .date-input:focus { border-color: var(--teal); }

  .status-msg {
    font-size: 12px;
    min-height: 18px;
    color: var(--grey);
    margin-top: 8px;
    line-height: 1.4;
  }
  .status-msg.ok  { color: var(--teal); }
  .status-msg.err { color: #c0392b; }
  .status-msg.info { color: var(--grey); }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 20px 0;
  }

  .demo-banner {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    background: rgba(0, 108, 103, 0.05);
    border: 1px solid rgba(0, 108, 103, 0.2);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 14px;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.55;
  }
  .demo-banner svg { color: var(--teal); }
  .demo-banner strong { color: var(--teal); }

  /* Spinner inside button */
  .spin {
    width: 12px; height: 12px;
    border: 2px solid rgba(0,0,0,0.15);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  .btn-teal .spin { border-color: rgba(255,255,255,0.3); border-top-color: #fff; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Subscriber list panel ────────────────────── */
  .list-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }
  .list-header .panel-label { margin-bottom: 2px; }
  .demo-note {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--coral);
    background: rgba(232, 93, 4, 0.08);
    border: 1px solid rgba(232, 93, 4, 0.25);
    border-radius: 4px;
    padding: 3px 8px;
    display: inline-block;
    margin-top: 6px;
  }
  .icon-btn {
    flex-shrink: 0;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--grey);
    padding: 6px 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: all 0.15s;
    margin-top: 2px;
  }
  .icon-btn:hover { border-color: var(--teal); color: var(--teal); }

  .sub-list {
    border: 1px solid var(--border);
    border-radius: 7px;
    overflow: hidden;
    min-height: 60px;
  }
  .sub-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    border-bottom: 1px solid var(--border);
    animation: fadeIn 0.2s ease;
  }
  .sub-row:last-child { border-bottom: none; }
  .pref-check {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
    cursor: pointer;
    user-select: none;
  }
  .pref-check input[type="checkbox"] {
    accent-color: var(--teal);
    width: 14px;
    height: 14px;
    cursor: pointer;
  }
  .pref-tag {
    display: inline-block;
    background: var(--soft);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 10px;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .sub-email {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub-date {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 11px;
    color: var(--grey);
    white-space: nowrap;
  }
  .rm {
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 11px;
    color: var(--grey);
    padding: 4px 8px;
    border-radius: 4px;
    transition: all 0.15s;
    line-height: 1;
  }
  .rm:hover { color: #c0392b; background: #fff0ee; }

  .sub-empty {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 13px;
    color: var(--grey);
    padding: 16px;
    text-align: center;
  }
  .sub-count {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 12px;
    color: var(--grey);
    margin-top: 10px;
  }

  .loading-dots { display: flex; gap: 5px; justify-content: center; padding: 20px; }
  .loading-dots span {
    width: 5px; height: 5px;
    background: #e0e0e0;
    border-radius: 50%;
    animation: bounce 1.2s ease-in-out infinite;
  }
  .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .loading-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce { 0%,80%,100% { transform: scale(0.5); opacity: 0.3; } 40% { transform: scale(1); opacity: 1; } }
  @keyframes fadeIn  { from { opacity: 0; } to { opacity: 1; } }

  /* ── Pipeline ────────────────────────────────── */
  .pipeline-section {
    padding-top: 44px;
    border-top: 1px solid var(--border);
  }
  .pipeline-header {
    text-align: center;
    margin-bottom: 28px;
  }
  h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: var(--black);
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .pipeline {
    display: grid;
    grid-template-columns: 1fr 28px 1fr 28px 1fr;
    align-items: start;
    margin-bottom: 20px;
  }
  @media (max-width: 640px) {
    .pipeline { grid-template-columns: 1fr; }
    .arrow { display: none; }
  }
  .step {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    background: var(--white);
    text-align: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.03);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .step:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.05);
  }
  .step-num {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: var(--grey);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .step-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 8px;
  }
  .step-body {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    text-align: left;
  }
  .arrow {
    display: flex;
    align-items: flex-start;
    padding-top: 26px;
    justify-content: center;
    color: #d0d0d0;
    font-size: 16px;
  }

  /* ── Login overlay ──────────────────────────── */
  #login-overlay {
    position: fixed;
    inset: 0;
    background: #fff;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .login-card {
    width: 100%;
    max-width: 380px;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 36px 32px 28px;
    background: var(--white);
    box-shadow: 0 8px 40px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .login-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 28px;
  }
  .login-logos img { height: 52px; object-fit: contain; }
  .login-logo-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
    flex-shrink: 0;
  }
  .login-title {
    font-family: 'DM Serif Display', serif;
    font-size: 20px;
    font-weight: 400;
    color: var(--black);
    text-align: center;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .login-sub {
    font-size: 12px;
    color: var(--grey);
    text-align: center;
    margin-bottom: 24px;
    font-weight: 500;
  }
  #login-form input[type="password"] {
    width: 100%;
    padding: 10px 13px;
    border: 1px solid var(--border);
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: var(--black);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
    display: block;
    margin-bottom: 10px;
  }
  #login-form input[type="password"]:focus { border-color: var(--teal); }

  /* ── Footer ──────────────────────────────────── */
  footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: space-between;
    font-size: 13px;
    font-weight: 500;
    color: #666;
    font-family: 'Space Grotesk', sans-serif;
  }
</style>

<script>
  const API      = import.meta.env.PUBLIC_API_URL ?? '';
  const PASSWORD = import.meta.env.PUBLIC_PASSWORD ?? '';

  // ── Auth gate ─────────────────────────────────
  (function initAuth() {
    if (!PASSWORD) return; // no password configured — skip login
    const overlay = document.getElementById('login-overlay');
    const mainEl  = document.querySelector('main');
    if (sessionStorage.getItem('sentinel_auth') !== PASSWORD) {
      overlay.style.display = 'flex';
      mainEl.style.display  = 'none';
    }
    document.getElementById('login-form').addEventListener('submit', e => {
      e.preventDefault();
      if (document.getElementById('pw-input').value === PASSWORD) {
        sessionStorage.setItem('sentinel_auth', PASSWORD);
        overlay.style.display = 'none';
        mainEl.style.display  = '';
        loadSubs();
      } else {
        document.getElementById('login-err').textContent = 'Incorrect password.';
      }
    });
  })();

  // ── Load subscriber list ──────────────────────
  async function loadSubs() {
    const list  = document.getElementById('list');
    const count = document.getElementById('count');
    try {
      const res  = await fetch(`${API}/phase3/subscribers`);
      if (!res.ok) throw new Error();
      const data = await res.json();
      if (!Array.isArray(data) || data.length === 0) {
        list.innerHTML    = '<div class="sub-empty">No subscribers yet.</div>';
        count.textContent = '';
      } else {
        const PREF_LABELS = {
          pref_welfare: 'Comp. & Gen. Welfare', pref_wildlife: 'Wild Animals',
          pref_agriculture: 'Livestock', pref_agricultural_subsidies: 'Farm Subsidies',
          pref_research_animals: 'Lab & Research', pref_marine: 'Marine', pref_trade: 'Trade & Export'
        };
        list.innerHTML = data.map(s => {
          const prefs = s.preferences || {};
          const activeTags = Object.entries(prefs)
            .filter(([,v]) => v)
            .map(([k]) => `<span class="pref-tag">${PREF_LABELS[k] || k}</span>`)
            .join('');
          return `
          <div class="sub-row" style="flex-wrap:wrap; gap:4px;">
            <div class="sub-email" title="${esc(s.email)}" style="flex:1;min-width:0;">${esc(s.email)}</div>
            <div class="sub-date">${s.created_at ? new Date(s.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : ''}</div>
            <button class="rm" data-email="${encodeURIComponent(s.email)}" aria-label="Remove ${esc(s.email)}">remove</button>
            ${activeTags ? `<div style="width:100%;display:flex;flex-wrap:wrap;gap:4px;padding-top:4px;">${activeTags}</div>` : ''}
          </div>`;
        }).join('');
        count.textContent = `${data.length} active subscriber${data.length === 1 ? '' : 's'}`;
      }
    } catch {
      list.innerHTML = '<div class="sub-empty">Cannot reach server.</div>';
    }
  }

  // ── Subscribe form ────────────────────────────
  document.getElementById('form').addEventListener('submit', async e => {
    e.preventDefault();
    const input  = document.getElementById('email');
    const btn    = document.getElementById('sub-btn');
    const status = document.getElementById('sub-status');
    const email  = input.value.trim();

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      status.className = 'status-msg err';
      status.textContent = 'Please enter a valid email address.';
      return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spin"></span> Subscribing…';
    status.className = 'status-msg';
    status.textContent = '';

    try {
      // Collect checkbox preferences
      const prefs = {};
      document.querySelectorAll('#pref-grid input[type="checkbox"]').forEach(cb => {
        prefs[cb.name] = cb.checked;
      });

      const res = await fetch(`${API}/phase3/subscribe`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email, preferences: prefs }),
      });
      if (res.ok) {
        status.className = 'status-msg ok';
        status.textContent = `Subscribed — ${esc(email)}`;
        input.value = '';
        await loadSubs();
      } else {
        const err = await res.json().catch(() => ({}));
        status.className = 'status-msg err';
        status.textContent = err.detail || 'Something went wrong.';
      }
    } catch {
      status.className = 'status-msg err';
      status.textContent = 'Network error — is the server running?';
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Subscribe';
    }
  });

  // ── Remove subscriber ─────────────────────────
  document.getElementById('list').addEventListener('click', async e => {
    const btn = e.target.closest('.rm');
    if (!btn) return;
    const email = decodeURIComponent(btn.dataset.email);
    if (!confirm(`Remove ${email} from the mailing list?`)) return;
    btn.textContent = '…';
    btn.disabled = true;
    try {
      const res = await fetch(`${API}/phase3/unsubscribe`, {
        method:  'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email }),
      });
      if (res.ok) { await loadSubs(); }
      else { btn.textContent = 'remove'; btn.disabled = false; }
    } catch {
      btn.textContent = 'remove';
      btn.disabled = false;
    }
  });

  // ── Run pipeline (202 + polling) ──────────────
  document.getElementById('run-btn').addEventListener('click', async () => {
    const btn       = document.getElementById('run-btn');
    const status    = document.getElementById('run-status');
    const dateInput = document.getElementById('run-date');
    let runDate = dateInput.value || new Date().toISOString().slice(0, 10);

    btn.disabled = true;
    btn.innerHTML = '<span class="spin"></span> Running…';
    status.className = 'status-msg info';
    status.textContent = `Pipeline started for ${runDate} — this can take a few minutes.`;

    try {
      // Step 1: kick off the pipeline — returns 202 + job_id immediately
      const kickRes = await fetch(`${API}/run?date=${runDate}`, { method: 'POST' });
      if (!kickRes.ok) {
        const err = await kickRes.json().catch(() => ({}));
        throw new Error(err.detail || 'Failed to start pipeline.');
      }
      const { job_id } = await kickRes.json();

      // Step 2: poll /run/status/{job_id} every 3 seconds until done or error
      let elapsed = 0;
      const POLL_MS = 10000;
      const MAX_WAIT_MS = 15 * 60 * 1000; // 15 min hard ceiling

      await new Promise((resolve, reject) => {
        const timer = setInterval(async () => {
          elapsed += POLL_MS;
          if (elapsed > MAX_WAIT_MS) {
            clearInterval(timer);
            return reject(new Error('Pipeline timed out after 15 minutes.'));
          }
          try {
            const pollRes = await fetch(`${API}/run/status/${job_id}`);
            if (!pollRes.ok) { clearInterval(timer); return reject(new Error('Status check failed.')); }
            const job = await pollRes.json();

            if (job.status === 'done') {
              clearInterval(timer);
              const p2 = (job.result?.phase2) || {};
              status.className = 'status-msg ok';
              status.textContent = `Done — ${job.result?.phase1_confirmed ?? 0} relevant docs found, ${p2.processed ?? 0} summarised. Digest ${job.result?.digest_built ? 'sent.' : 'not sent (no docs).'}`;
              await loadSubs();
              resolve();
            } else if (job.status === 'error') {
              clearInterval(timer);
              reject(new Error(job.error || 'Pipeline encountered an error.'));
            }
            // else still 'running' — keep polling
          } catch (pollErr) {
            clearInterval(timer);
            reject(pollErr);
          }
        }, POLL_MS);
      });

    } catch (err) {
      status.className = 'status-msg err';
      status.textContent = err.message || 'Network error — is the server running?';
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Send digest';
    }
  });

  // ── Init ──────────────────────────────────────
  document.getElementById('refresh').addEventListener('click', loadSubs);
  document.getElementById('run-date').value = new Date().toISOString().slice(0, 10);

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  loadSubs();
</script>
