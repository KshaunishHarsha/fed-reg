---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<main>

  <!-- NAV -->
  <nav>
    <span class="brand">Open<span>Paws</span> · Federal Register Sentinel</span>
    <span class="label">DEMO</span>
  </nav>

  <!-- INTRO -->
  <section class="intro">
    <p class="kicker">Animal Legal Defense Fund</p>
    <h1>Daily regulatory intelligence,<br /><em>automated.</em></h1>
    <p class="lead">The Federal Register publishes hundreds of documents daily. This pipeline finds the ones that matter to animal law — and emails your team a plain-language digest every morning.</p>
  </section>

  <!-- SUBSCRIBE + LIST -->
  <section class="two-col">

    <div class="panel">
      <p class="panel-label">Subscribe</p>
      <p class="panel-sub">Receive the daily digest when animal-relevant regulations are published.</p>
      <form id="form" novalidate>
        <div class="row">
          <label for="email" class="sr-only">Email address</label>
          <input id="email" type="email" placeholder="you@aldf.org" autocomplete="email" required />
          <button type="submit" id="btn">
            <span id="btn-text">Subscribe</span>
            <span id="btn-spin" hidden class="spin"></span>
          </button>
        </div>
        <p id="status" role="alert" aria-live="polite"></p>
      </form>
    </div>

    <div class="panel">
      <div class="panel-top">
        <p class="panel-label">Active subscribers</p>
        <span class="dev-tag">Only visible in this demo — hidden in production</span>
        <button id="refresh" class="refresh-btn" aria-label="Refresh">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        </button>
      </div>
      <div id="list" class="list-body">
        <div class="dots"><span></span><span></span><span></span></div>
      </div>
      <p id="count" class="count"></p>
    </div>

  </section>

  <!-- PIPELINE -->
  <section class="pipeline-section">
    <p class="kicker">How it works</p>
    <h2>Three phases. Zero manual steps.</h2>

    <div class="pipeline">
      <div class="step">
        <p class="step-num">01</p>
        <p class="step-title">Ingest & Filter</p>
        <p class="step-body">Pulls new publications daily from 7 federal agencies. A four-layer pipeline — agency filter, keyword scoring, full-text PDF scan, AI verification — narrows ~500 documents to the handful that are animal-relevant.</p>
      </div>
      <div class="arrow">→</div>
      <div class="step">
        <p class="step-num">02</p>
        <p class="step-title">Summarise</p>
        <p class="step-body">Each confirmed document is routed by page length and processed by GPT-4o-mini. Output includes a plain-language summary, advocacy relevance, suggested actions, and talking points — validated against a strict schema.</p>
      </div>
      <div class="arrow">→</div>
      <div class="step">
        <p class="step-num">03</p>
        <p class="step-title">Deliver</p>
        <p class="step-body">Summaries are compiled into a structured HTML digest sorted by urgency — proposed rules with open comment windows first, then final rules, then potential matches — and emailed to all subscribers.</p>
      </div>
    </div>

    <div class="chips">
      <span class="chip">Agency pre-filter</span>
      <span class="chip">Keyword scoring</span>
      <span class="chip">PDF scan</span>
      <span class="chip">AI verify</span>
      <span class="chip teal">LLM summary</span>
      <span class="chip teal">Email digest</span>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <span>OpenPaws.ai · Built for the Animal Legal Defense Fund</span>
    <span>Summaries are AI-generated and informational only — not legal advice.</span>
  </footer>

</main>
</Layout>

<style>
  /* ── Tokens ──────────────────────────────────── */
  :root {
    --black:  #000;
    --white:  #fff;
    --teal:   #006C67;
    --grey:   #888;
    --border: #e8e8e8;
    --soft:   #f7f7f7;
    --text:   #111;
    --muted:  #666;
  }
  .sr-only { position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0); }

  /* ── Shell ───────────────────────────────────── */
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 28px 56px;
  }

  /* ── Nav ─────────────────────────────────────── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 44px;
  }
  .brand {
    font-family: 'DM Serif Display', serif;
    font-size: 17px;
    color: var(--black);
    letter-spacing: -0.01em;
  }
  .brand span { color: var(--teal); }
  .label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--grey);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 4px;
  }

  /* ── Intro ───────────────────────────────────── */
  .intro { margin-bottom: 40px; }
  .kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--grey);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 400;
    color: var(--black);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  h1 em { color: var(--teal); font-style: italic; }
  .lead {
    font-size: 15px;
    color: var(--muted);
    max-width: 580px;
    line-height: 1.65;
  }

  /* ── Two-col ─────────────────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 48px;
  }
  @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }

  .panel {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    background: var(--white);
  }
  .panel-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 6px;
  }
  .panel-sub {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 18px;
    line-height: 1.55;
  }

  /* Form */
  .row { display: flex; gap: 8px; margin-bottom: 8px; }
  input[type="email"] {
    flex: 1;
    padding: 9px 13px;
    border: 1px solid var(--border);
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: var(--black);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
  }
  input[type="email"]::placeholder { color: #c0c0c0; }
  input[type="email"]:focus { border-color: var(--teal); }

  button[type="submit"] {
    padding: 9px 18px;
    background: var(--teal);
    border: none;
    border-radius: 7px;
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  button[type="submit"]:hover { opacity: 0.85; }
  button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }

  .spin {
    width: 12px; height: 12px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: inline-block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  #status {
    font-size: 12px;
    min-height: 16px;
    color: var(--grey);
  }
  #status.ok  { color: var(--teal); }
  #status.err { color: #c0392b; }

  /* Subscriber panel */
  .panel-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }
  .panel-top .panel-label { margin-bottom: 0; flex: 1; }
  .dev-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.06em;
    color: #FF8552;
    border: 1px solid rgba(255,133,82,0.25);
    padding: 3px 8px;
    border-radius: 3px;
    background: rgba(255,133,82,0.06);
    white-space: nowrap;
  }
  .refresh-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--grey);
    padding: 5px 7px;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: all 0.15s;
  }
  .refresh-btn:hover { border-color: var(--teal); color: var(--teal); }

  .list-body { max-height: 150px; overflow-y: auto; }
  .sub-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 0;
    border-bottom: 1px solid var(--border);
    animation: fadeIn 0.2s ease;
  }
  .sub-row:last-child { border-bottom: none; }
  .sub-email {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text);
  }
  .sub-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #c8c8c8;
  }
  .rm {
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #ccc;
    padding: 2px 6px;
    border-radius: 4px;
    transition: all 0.15s;
    line-height: 1;
  }
  .rm:hover { color: #c0392b; background: #fff0ee; }

  .empty {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #ccc;
    padding: 14px 0;
    text-align: center;
  }
  .count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #c8c8c8;
    margin-top: 12px;
  }

  .dots { display: flex; gap: 5px; justify-content: center; padding: 18px 0; }
  .dots span {
    width: 5px; height: 5px;
    background: #e0e0e0;
    border-radius: 50%;
    animation: bounce 1.2s ease-in-out infinite;
  }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,80%,100% { transform: scale(0.5); opacity: 0.3; } 40% { transform: scale(1); opacity: 1; } }
  @keyframes fadeIn  { from { opacity: 0; } to { opacity: 1; } }

  /* ── Pipeline ────────────────────────────────── */
  .pipeline-section {
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: var(--black);
    letter-spacing: -0.015em;
    margin-bottom: 28px;
    line-height: 1.2;
  }
  .pipeline {
    display: grid;
    grid-template-columns: 1fr 24px 1fr 24px 1fr;
    align-items: start;
    margin-bottom: 20px;
  }
  @media (max-width: 640px) {
    .pipeline { grid-template-columns: 1fr; }
    .arrow { display: none; }
  }
  .step {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px 18px;
    background: var(--white);
  }
  .step-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--grey);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .step-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 8px;
  }
  .step-body {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }
  .arrow {
    display: flex;
    align-items: flex-start;
    padding-top: 28px;
    justify-content: center;
    color: #d0d0d0;
    font-size: 16px;
  }

  /* Chips */
  .chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--grey);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 5px 10px;
    background: var(--soft);
  }
  .chip.teal {
    color: var(--teal);
    border-color: rgba(0, 108, 103, 0.2);
    background: rgba(0, 108, 103, 0.04);
  }

  /* ── Footer ──────────────────────────────────── */
  footer {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: space-between;
    font-size: 11px;
    color: #c0c0c0;
    font-family: 'JetBrains Mono', monospace;
  }
</style>

<script>
  // Relative URLs — proxied by Astro dev server in dev, same-origin in production
  const API = '';

  async function loadSubs() {
    const list  = document.getElementById('list');
    const count = document.getElementById('count');
    try {
      const res  = await fetch(`${API}/phase3/subscribers`);
      const data = await res.json();
      if (!data.length) {
        list.innerHTML  = '<div class="empty">No subscribers yet.</div>';
        count.textContent = '';
      } else {
        list.innerHTML = data.map(s => `
          <div class="sub-row">
            <div>
              <div class="sub-email">${esc(s.email)}</div>
              <div class="sub-date">${s.created_at ? new Date(s.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : ''}</div>
            </div>
            <button class="rm" data-email="${encodeURIComponent(s.email)}" title="Remove">remove</button>
          </div>`).join('');
        count.textContent = `${data.length} active`;
      }
    } catch {
      list.innerHTML = '<div class="empty">Cannot reach server.</div>';
    }
  }

  document.getElementById('form').addEventListener('submit', async e => {
    e.preventDefault();
    const input  = document.getElementById('email');
    const btn    = document.getElementById('btn');
    const label  = document.getElementById('btn-text');
    const spin   = document.getElementById('btn-spin');
    const status = document.getElementById('status');
    const email  = input.value.trim();

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      status.className = 'err';
      status.textContent = 'Please enter a valid email address.';
      return;
    }
    btn.disabled = true; label.hidden = true; spin.hidden = false;
    status.className = ''; status.textContent = '';
    try {
      const res = await fetch(`${API}/phase3/subscribe`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) {
        status.className = 'ok';
        status.textContent = `Subscribed — ${esc(email)}`;
        input.value = '';
        await loadSubs();
      } else {
        const err = await res.json();
        status.className = 'err';
        status.textContent = err.detail || 'Something went wrong.';
      }
    } catch {
      status.className = 'err';
      status.textContent = 'Network error — is the server running?';
    } finally {
      btn.disabled = false; label.hidden = false; spin.hidden = true;
    }
  });

  document.getElementById('list').addEventListener('click', async e => {
    const btn = e.target.closest('.rm');
    if (!btn) return;
    const email = decodeURIComponent(btn.dataset.email);
    if (!confirm(`Remove ${email} from the mailing list?`)) return;
    btn.textContent = '...'; btn.disabled = true;
    try {
      const res = await fetch(`${API}/phase3/unsubscribe`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) { await loadSubs(); }
      else { btn.textContent = 'remove'; btn.disabled = false; }
    } catch {
      btn.textContent = 'remove'; btn.disabled = false;
    }
  });

  document.getElementById('refresh').addEventListener('click', loadSubs);

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  loadSubs();
</script>
