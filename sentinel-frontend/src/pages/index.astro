---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- ======================================================= -->
<!-- NAV                                                       -->
<!-- ======================================================= -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Open Paws home">
      <span class="nav-logo-symbol">⬡</span>
      <span class="nav-logo-text">Open<span class="teal">Paws</span></span>
    </a>
    <div class="nav-links">
      <a href="#how-it-works">How it works</a>
      <a href="#subscribe" class="nav-cta">Subscribe</a>
    </div>
  </div>
</nav>

<!-- ======================================================= -->
<!-- HERO                                                      -->
<!-- ======================================================= -->
<header class="hero">
  <div class="hero-bg-glow" aria-hidden="true"></div>
  <div class="container">
    <p class="hero-eyebrow mono">[ Federal Register Sentinel ]</p>
    <h1 class="hero-title">Every animal-relevant<br /><em>federal rule. Every day.</em></h1>
    <p class="hero-subtitle">
      An open-source AI pipeline built for the Animal Legal Defense Fund — scanning the Federal Register daily, filtering for animal law, and delivering plain-language digest emails to advocates who need to act.
    </p>
    <div class="hero-badges">
      <span class="badge">Phase 1 ✓</span>
      <span class="badge">Phase 2 ✓</span>
      <span class="badge">Phase 3 ✓</span>
      <span class="badge badge-teal">Live & Running</span>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
      <span class="mono" style="font-size:11px;color:#555">scroll to explore</span>
      <div class="scroll-arrow"></div>
    </div>
  </div>
</header>

<!-- ======================================================= -->
<!-- SUBSCRIBE + LIVE LIST                                     -->
<!-- ======================================================= -->
<section class="section subscribe-section" id="subscribe">
  <div class="container">
    <div class="section-label mono">[ 01 — Mailing List ]</div>
    <h2 class="section-title">Get the daily digest.</h2>
    <p class="section-sub">Enter your email to receive the Federal Register Sentinel digest whenever animal-relevant regulations are published.</p>

    <div class="subscribe-grid">

      <!-- Subscribe form -->
      <div class="subscribe-card">
        <h3 class="card-heading">Subscribe</h3>
        <form id="subscribe-form" novalidate>
          <div class="input-row">
            <label for="email-input" class="sr-only">Email address</label>
            <input
              id="email-input"
              type="email"
              placeholder="attorney@aldf.org"
              autocomplete="email"
              required
              class="email-input"
            />
            <button type="submit" class="btn-primary" id="subscribe-btn">
              <span id="subscribe-btn-text">Subscribe</span>
              <span id="subscribe-btn-spinner" class="spinner" hidden aria-hidden="true"></span>
            </button>
          </div>
          <div id="subscribe-status" class="form-status" role="alert" aria-live="polite"></div>
        </form>
        <p class="form-note mono">No spam. Only regulatory updates that matter. Unsubscribe any time.</p>
      </div>

      <!-- Live subscriber list -->
      <div class="subscribers-card">
        <div class="subscribers-header">
          <h3 class="card-heading">Active Subscribers</h3>
          <button id="refresh-btn" class="btn-ghost" aria-label="Refresh subscriber list">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          </button>
        </div>
        <div id="subscribers-list" class="subscribers-list">
          <div class="loading-state">
            <div class="loading-dot"></div>
            <div class="loading-dot"></div>
            <div class="loading-dot"></div>
          </div>
        </div>
        <div id="subscribers-count" class="subscribers-count mono"></div>
      </div>

    </div>
  </div>
</section>

<!-- ======================================================= -->
<!-- HOW IT WORKS                                             -->
<!-- ======================================================= -->
<section class="section" id="how-it-works">
  <div class="container">
    <div class="section-label mono">[ 02 — Architecture ]</div>
    <h2 class="section-title">Three phases. One pipeline.</h2>
    <p class="section-sub">Every morning at 7:30 AM, the sentinel wakes up and runs a fully automated regulatory intelligence cycle.</p>

    <div class="phases-grid">

      <div class="phase-card">
        <div class="phase-number mono">01</div>
        <div class="phase-icon">🔍</div>
        <h3 class="phase-title">Ingestion & Filtering</h3>
        <p class="phase-desc">Connects directly to the official Federal Register API for 7 target agencies — USDA, FDA, NOAA, Fish & Wildlife Service, NIH, and more. A 4-layer filter pipeline reduces ~500 daily documents down to a precise set of animal-relevant items.</p>
        <ul class="phase-layers">
          <li><span class="mono teal">L1</span> Agency + type pre-filter</li>
          <li><span class="mono teal">L2</span> Anchor & contextual keyword scoring</li>
          <li><span class="mono teal">L2a</span> Full-text PDF deep scan</li>
          <li><span class="mono teal">L3</span> GPT-4o-mini AI verification</li>
        </ul>
      </div>

      <div class="phase-connector" aria-hidden="true">→</div>

      <div class="phase-card">
        <div class="phase-number mono">02</div>
        <div class="phase-icon">✍️</div>
        <h3 class="phase-title">LLM Summarization</h3>
        <p class="phase-desc">Routes each confirmed document through one of three tiers based on page length. GPT-4o-mini generates plain-language summaries with advocacy relevance, suggested actions, and talking points — all validated against a strict XML schema.</p>
        <ul class="phase-layers">
          <li><span class="mono teal">T1</span> Short docs (&lt;15 pages) — abstract direct</li>
          <li><span class="mono teal">T2</span> Medium (15–50 pages) — boilerplate pruned</li>
          <li><span class="mono teal">T3</span> Long (&gt;50 pages) — context block reuse</li>
        </ul>
      </div>

      <div class="phase-connector" aria-hidden="true">→</div>

      <div class="phase-card">
        <div class="phase-number mono">03</div>
        <div class="phase-icon">📬</div>
        <h3 class="phase-title">Digest & Delivery</h3>
        <p class="phase-desc">Validates all summaries, organizes them into a structured HTML + plain-text digest, and emails it to all active subscribers. Documents are sorted into three priority sections — Action Required, Watchdog, and Potential Matches.</p>
        <ul class="phase-layers">
          <li><span class="mono teal">A</span> Proposed rules with open comment windows</li>
          <li><span class="mono teal">B</span> Final rules &amp; informational notices</li>
          <li><span class="mono teal">C</span> Borderline / unconfirmed relevance</li>
        </ul>
      </div>

    </div>

    <!-- Stats row -->
    <div class="stats-row">
      <div class="stat">
        <div class="stat-number">7</div>
        <div class="stat-label mono">Target Agencies</div>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <div class="stat-number">4</div>
        <div class="stat-label mono">Filter Layers</div>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <div class="stat-number">3</div>
        <div class="stat-label mono">Summarization Tiers</div>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <div class="stat-number">0</div>
        <div class="stat-label mono">Manual Steps</div>
      </div>
    </div>
  </div>
</section>

<!-- ======================================================= -->
<!-- TECH STACK                                               -->
<!-- ======================================================= -->
<section class="section tech-section">
  <div class="container">
    <div class="section-label mono">[ 03 — Technology ]</div>
    <h2 class="section-title">Built to last.</h2>
    <div class="tech-grid">
      <div class="tech-item">
        <span class="tech-name mono">Federal Register API</span>
        <span class="tech-desc">Official government feed — no scraping, no maintenance</span>
      </div>
      <div class="tech-item">
        <span class="tech-name mono">OpenAI GPT-4o-mini</span>
        <span class="tech-desc">Cost-efficient AI — only called after keyword pre-filter</span>
      </div>
      <div class="tech-item">
        <span class="tech-name mono">Pydantic v2 + Instructor</span>
        <span class="tech-desc">Structured validation with automatic self-correction loops</span>
      </div>
      <div class="tech-item">
        <span class="tech-name mono">Supabase / PostgreSQL</span>
        <span class="tech-desc">Secure persistent storage with idempotency caching</span>
      </div>
      <div class="tech-item">
        <span class="tech-name mono">FastAPI + asyncpg</span>
        <span class="tech-desc">Single-process async Python — all phases in one port</span>
      </div>
      <div class="tech-item">
        <span class="tech-name mono">PyMuPDF</span>
        <span class="tech-desc">Full-text PDF extraction for docs without abstract</span>
      </div>
    </div>
  </div>
</section>

<!-- ======================================================= -->
<!-- PROJECT INFO                                             -->
<!-- ======================================================= -->
<section class="section info-section">
  <div class="container">
    <div class="section-label mono">[ 04 — About ]</div>
    <h2 class="section-title">The problem we're solving.</h2>

    <div class="info-grid">
      <div class="info-block">
        <h3 class="info-heading">The Burden</h3>
        <p>Attorneys, policy analysts, and legal leads at the Animal Legal Defense Fund must manually review the Federal Register every day — hundreds of pages of dense government text — to find the handful of entries relevant to animal law. Missing a public comment deadline has real consequences for advocacy efforts.</p>
      </div>
      <div class="info-block">
        <h3 class="info-heading">The Solution</h3>
        <p>Federal Register Sentinel eliminates this manual burden entirely. The system automatically monitors all relevant agencies, applies a calibrated multi-layer filter tuned for high recall (false negatives are worse than false positives), and delivers a clean, actionable digest every morning.</p>
      </div>
      <div class="info-block">
        <h3 class="info-heading">Open Source</h3>
        <p>This tool is part of OpenPaws.ai — an open-source initiative building AI tools, hackathons, and research to power the animal advocacy movement. Every decision, keyword score, and AI verification reason is saved to a permanent audit log for full transparency.</p>
      </div>
      <div class="info-block">
        <h3 class="info-heading">What's Excluded</h3>
        <p>There is no human review queue (adds operational burden), no state or international content (out of scope), no live streaming webhooks (government feed updates once daily), and no silent shutdowns — even on zero-result days, a confirmation digest is sent.</p>
      </div>
    </div>

    <!-- Pipeline flow diagram -->
    <div class="pipeline-diagram">
      <div class="pipeline-step">
        <div class="pipeline-icon">📡</div>
        <div class="pipeline-text mono">FR API Pull</div>
      </div>
      <div class="pipeline-arrow">→</div>
      <div class="pipeline-step">
        <div class="pipeline-icon">🔎</div>
        <div class="pipeline-text mono">Keyword Filter</div>
      </div>
      <div class="pipeline-arrow">→</div>
      <div class="pipeline-step">
        <div class="pipeline-icon">🤖</div>
        <div class="pipeline-text mono">AI Verification</div>
      </div>
      <div class="pipeline-arrow">→</div>
      <div class="pipeline-step">
        <div class="pipeline-icon">✍️</div>
        <div class="pipeline-text mono">LLM Summary</div>
      </div>
      <div class="pipeline-arrow">→</div>
      <div class="pipeline-step">
        <div class="pipeline-icon">✅</div>
        <div class="pipeline-text mono">Validate & Store</div>
      </div>
      <div class="pipeline-arrow">→</div>
      <div class="pipeline-step pipeline-step-teal">
        <div class="pipeline-icon">📬</div>
        <div class="pipeline-text mono">Email Digest</div>
      </div>
    </div>
  </div>
</section>

<!-- ======================================================= -->
<!-- FOOTER                                                   -->
<!-- ======================================================= -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="nav-logo-symbol teal">⬡</span>
        <span style="font-family:'DM Serif Display',serif;font-size:20px;">OpenPaws.ai</span>
      </div>
      <p class="footer-tagline">Building AI for the animal advocacy movement.</p>
    </div>
    <div class="footer-divider" aria-hidden="true"></div>
    <div class="footer-bottom">
      <p class="mono" style="font-size:12px;color:#444;">[ EST. 2024 ] — Federal Register Sentinel is an open-source project. All summaries are AI-generated and informational only — not legal advice.</p>
      <div class="footer-links">
        <a href="https://federalregister.gov" target="_blank" rel="noopener noreferrer" class="footer-link">Federal Register ↗</a>
        <a href="https://regulations.gov" target="_blank" rel="noopener noreferrer" class="footer-link">Regulations.gov ↗</a>
        <a href="http://localhost:8000/docs" target="_blank" rel="noopener noreferrer" class="footer-link">API Docs ↗</a>
      </div>
    </div>
  </div>
</footer>

</Layout>

<!-- ======================================================= -->
<!-- STYLES                                                   -->
<!-- ======================================================= -->
<style>
  /* ── Utilities ─────────────────────────────────── */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
  .mono { font-family: 'JetBrains Mono', monospace; }
  .teal { color: #006C67; }
  .section { padding: 100px 0; border-top: 1px solid #111; }
  .section-label { font-size: 11px; font-weight: 500; color: #555; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 16px; }
  .section-title { font-family: 'DM Serif Display', serif; font-size: clamp(32px, 5vw, 52px); color: #fff; line-height: 1.1; margin-bottom: 16px; }
  .section-sub { font-size: 17px; color: #888; max-width: 560px; line-height: 1.65; margin-bottom: 56px; }

  /* ── Nav ──────────────────────────────────────── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid #111;
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 24px;
    display: flex; align-items: center; justify-content: space-between;
    height: 60px;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 8px;
    font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 16px;
    color: #fff; text-decoration: none;
  }
  .nav-logo:hover { text-decoration: none; }
  .nav-logo-symbol { color: #006C67; font-size: 18px; }
  .nav-links { display: flex; align-items: center; gap: 32px; }
  .nav-links a { font-size: 14px; color: #888; font-weight: 500; transition: color 0.2s; text-decoration: none; }
  .nav-links a:hover { color: #fff; text-decoration: none; }
  .nav-cta {
    background: #006C67 !important; color: #fff !important;
    padding: 8px 20px; border-radius: 6px; font-weight: 600 !important;
    transition: opacity 0.2s !important;
  }
  .nav-cta:hover { opacity: 0.85; }

  /* ── Hero ──────────────────────────────────────── */
  .hero {
    padding: 160px 0 120px;
    position: relative; overflow: hidden;
    border-bottom: 1px solid #111;
  }
  .hero-bg-glow {
    position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(0,108,103,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-eyebrow { font-size: 11px; color: #555; letter-spacing: 0.15em; margin-bottom: 24px; }
  .hero-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(42px, 7vw, 80px);
    line-height: 1.05; color: #fff; margin-bottom: 24px;
  }
  .hero-title em { color: #006C67; font-style: italic; }
  .hero-subtitle {
    font-size: 18px; color: #777; max-width: 600px;
    line-height: 1.65; margin-bottom: 40px;
  }
  .hero-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 60px; }
  .badge {
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    padding: 5px 12px; border: 1px solid #222; border-radius: 4px; color: #555;
  }
  .badge-teal { border-color: #006C67; color: #006C67; }
  .hero-scroll-hint { display: flex; flex-direction: column; align-items: flex-start; gap: 8px; }
  .scroll-arrow {
    width: 1px; height: 40px; background: linear-gradient(to bottom, #006C67, transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

  /* ── Subscribe Section ─────────────────────────── */
  .subscribe-section { padding-bottom: 80px; }
  .subscribe-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 24px; align-items: start;
  }
  @media (max-width: 700px) { .subscribe-grid { grid-template-columns: 1fr; } }

  .subscribe-card, .subscribers-card {
    background: #0a0a0a; border: 1px solid #1a1a1a;
    border-radius: 14px; padding: 32px;
  }
  .card-heading {
    font-family: 'DM Serif Display', serif; font-size: 22px; color: #fff;
    margin-bottom: 24px;
  }
  .input-row { display: flex; gap: 10px; margin-bottom: 12px; }
  .email-input {
    flex: 1; padding: 12px 16px;
    background: #000; border: 1px solid #222; border-radius: 8px;
    color: #fff; font-family: 'Space Grotesk', sans-serif; font-size: 15px;
    transition: border-color 0.2s;
    outline: none;
  }
  .email-input::placeholder { color: #444; }
  .email-input:focus { border-color: #006C67; }
  .btn-primary {
    padding: 12px 24px; background: #006C67; border: none; border-radius: 8px;
    color: #fff; font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 600;
    cursor: pointer; white-space: nowrap; display: flex; align-items: center; gap: 8px;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .form-status {
    font-size: 14px; min-height: 20px; padding: 0 2px;
    transition: all 0.2s;
  }
  .form-status.success { color: #006C67; }
  .form-status.error { color: #FF8552; }
  .form-note { font-size: 12px; color: #444; margin-top: 16px; }

  /* Spinner */
  .spinner {
    width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,0.2);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: inline-block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Subscriber list */
  .subscribers-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .btn-ghost {
    background: none; border: 1px solid #222; border-radius: 6px;
    color: #555; padding: 6px 8px; cursor: pointer;
    display: flex; align-items: center; transition: all 0.2s;
  }
  .btn-ghost:hover { border-color: #006C67; color: #006C67; }
  .subscribers-list { min-height: 80px; }
  .subscriber-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid #111;
    font-size: 14px; animation: fadeIn 0.3s ease;
  }
  .subscriber-item:last-child { border-bottom: none; }
  .subscriber-email { color: #ccc; font-family: 'JetBrains Mono', monospace; }
  .subscriber-date { color: #444; font-size: 11px; font-family: 'JetBrains Mono', monospace; }
  .remove-btn {
    background: none; border: none; cursor: pointer; color: #333;
    font-size: 14px; padding: 2px 6px; border-radius: 4px;
    transition: all 0.2s; line-height: 1;
  }
  .remove-btn:hover { color: #FF8552; background: rgba(255,133,82,0.08); }
  .subscribers-count { font-size: 11px; color: #444; margin-top: 16px; letter-spacing: 0.05em; }
  .empty-state { color: #444; font-size: 14px; padding: 16px 0; text-align: center; }
  .loading-state { display: flex; gap: 6px; padding: 16px 0; justify-content: center; }
  .loading-dot {
    width: 6px; height: 6px; background: #333; border-radius: 50%;
    animation: loadBounce 1.2s ease-in-out infinite;
  }
  .loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .loading-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes loadBounce { 0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; } 40% { transform: scale(1); opacity: 1; } }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

  /* ── Phases Grid ──────────────────────────────── */
  .phases-grid {
    display: grid;
    grid-template-columns: 1fr 32px 1fr 32px 1fr;
    gap: 0; align-items: start; margin-bottom: 64px;
  }
  @media (max-width: 800px) {
    .phases-grid { grid-template-columns: 1fr; }
    .phase-connector { display: none; }
  }
  .phase-card {
    background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 14px; padding: 32px;
    transition: border-color 0.3s;
  }
  .phase-card:hover { border-color: #006C67; }
  .phase-connector {
    display: flex; align-items: flex-start; padding-top: 52px;
    justify-content: center; color: #333; font-size: 20px;
  }
  .phase-number { font-size: 11px; color: #444; letter-spacing: 0.15em; margin-bottom: 16px; }
  .phase-icon { font-size: 28px; margin-bottom: 16px; }
  .phase-title { font-family: 'DM Serif Display', serif; font-size: 22px; color: #fff; margin-bottom: 12px; }
  .phase-desc { font-size: 14px; color: #666; line-height: 1.65; margin-bottom: 20px; }
  .phase-layers { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .phase-layers li { font-size: 13px; color: #555; display: flex; align-items: baseline; gap: 8px; }
  .phase-layers .mono { font-size: 11px; }

  /* Stats */
  .stats-row {
    display: flex; align-items: center; justify-content: center;
    gap: 0; border: 1px solid #1a1a1a; border-radius: 14px;
    overflow: hidden; background: #0a0a0a;
  }
  .stat { flex: 1; text-align: center; padding: 32px 16px; }
  .stat-number {
    font-family: 'DM Serif Display', serif; font-size: 48px; color: #006C67;
    line-height: 1; margin-bottom: 8px;
  }
  .stat-label { font-size: 11px; color: #444; letter-spacing: 0.12em; }
  .stat-divider { width: 1px; height: 64px; background: #1a1a1a; flex-shrink: 0; }
  @media (max-width: 600px) {
    .stats-row { flex-direction: column; }
    .stat-divider { width: 100%; height: 1px; }
  }

  /* ── Tech Grid ────────────────────────────────── */
  .tech-section { background: #030303; }
  .tech-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    border: 1px solid #1a1a1a; border-radius: 14px; overflow: hidden;
    background: #1a1a1a;
  }
  @media (max-width: 700px) { .tech-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .tech-grid { grid-template-columns: 1fr; } }
