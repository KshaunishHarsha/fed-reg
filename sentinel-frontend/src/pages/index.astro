---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<main>

  <!-- NAV -->
  <nav>
    <span class="brand">Open<span>Paws</span> · Federal Register Sentinel</span>
    <span class="label">DEMO</span>
  </nav>

  <!-- INTRO -->
  <section class="intro" style="text-align: center;">
    <div style="display: flex; justify-content: center; align-items: center; gap: 40px; margin-bottom: 32px;">
      <img src="/openpawslogo.png" alt="OpenPaws Logo" style="height: 70px; object-fit: contain;" />
      <img src="/ALDF_Logos_full_vertical_color_RGB.jpg" alt="ALDF Logo" style="height: 70px; object-fit: contain;" />
    </div>
    <p class="kicker">Animal Legal Defense Fund</p>
    <h1>Daily regulatory intelligence,<br /><em>automated.</em></h1>
    <p class="lead" style="margin: 0 auto;">The Federal Register publishes hundreds of documents daily. This pipeline finds the ones that matter to animal law — and emails your team a plain-language digest every morning.</p>
  </section>

  <!-- SUBSCRIBE + LIST -->
  <section class="two-col">

    <!-- Left: subscribe form + run button -->
    <div class="panel">
      <p class="panel-label">Subscribe</p>
      <p class="panel-sub">Receive the daily digest when animal-relevant regulations are published.</p>

      <form id="form" novalidate>
        <label for="email" class="sr-only">Email address</label>
        <input id="email" type="email" placeholder="you@aldf.org" autocomplete="email" required />
        <button type="submit" id="sub-btn" class="btn btn-teal">Subscribe</button>
        <p id="sub-status" class="status-msg" role="alert" aria-live="polite"></p>
      </form>

      <div class="divider"></div>

      <p class="panel-label">Run pipeline</p>
      <p class="panel-sub">Fetch today's Federal Register, filter, summarise, and send the digest to all subscribers.</p>
      <div style="display: flex; gap: 8px; align-items: center;">
        <input type="date" id="run-date" class="date-input" />
        <button id="run-btn" class="btn btn-outline">Send digest</button>
      </div>
      <p id="run-status" class="status-msg" role="alert" aria-live="polite"></p>
    </div>

    <!-- Right: live subscriber list -->
    <div class="panel">
      <div class="list-header">
        <div>
          <p class="panel-label">Active subscribers</p>
          <p class="demo-note">Only visible in this demo — hidden in production</p>
        </div>
        <button id="refresh" class="icon-btn" aria-label="Refresh list">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        </button>
      </div>

      <div id="list" class="sub-list">
        <div class="loading-dots"><span></span><span></span><span></span></div>
      </div>
      <p id="count" class="sub-count"></p>
    </div>

  </section>

  <!-- PIPELINE -->
  <section class="pipeline-section">
    <div class="pipeline-header">
      <p class="kicker">How it works</p>
      <h2>Three phases. Zero manual steps.</h2>
      <p style="font-size: 14px; color: var(--muted); margin-top: 16px; max-width: 650px; margin-left: auto; margin-right: auto; line-height: 1.6;">
        Only one mail will be sent for a day. State will be tracked to ensure no double mails are sent, but for this demo we have enabled a bypass allowing the same document to come again when hitting the same date for demo testing.
      </p>
    </div>

    <div class="pipeline">
      <div class="step">
        <p class="step-num">01</p>
        <p class="step-title">Ingest & Filter</p>
        <p class="step-body">Pulls new publications daily from 7 federal agencies. A four-layer pipeline — agency filter, keyword scoring, full-text PDF scan, AI verification — narrows ~500 documents to the handful that are animal-relevant.</p>
      </div>
      <div class="arrow">→</div>
      <div class="step">
        <p class="step-num">02</p>
        <p class="step-title">Summarise</p>
        <p class="step-body">Each confirmed document is routed by page length and processed by GPT-4o-mini. Output includes a plain-language summary, advocacy relevance, suggested actions, and talking points — validated against a strict schema.</p>
      </div>
      <div class="arrow">→</div>
      <div class="step">
        <p class="step-num">03</p>
        <p class="step-title">Deliver</p>
        <p class="step-body">Summaries are compiled into a structured HTML digest sorted by urgency — proposed rules with open comment windows first, then final rules, then potential matches — and emailed to all subscribers.</p>
      </div>
    </div>

    <div class="chips">
      <span class="chip">Agency pre-filter</span>
      <span class="chip">Keyword scoring</span>
      <span class="chip">PDF scan</span>
      <span class="chip">AI verify</span>
      <span class="chip teal">LLM summary</span>
      <span class="chip teal">Email digest</span>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <span>OpenPaws.ai · Built for the Animal Legal Defense Fund</span>
    <span>Summaries are AI-generated and informational only — not legal advice.</span>
  </footer>

</main>
</Layout>

<style is:global>
  /* ── Tokens ──────────────────────────────────── */
  :root {
    --black:  #000;
    --white:  #fff;
    --teal:   #006C67;
    --grey:   #888;
    --border: #e8e8e8;
    --soft:   #f7f7f7;
    --text:   #111;
    --muted:  #666;
    --coral:  #FF8552;
  }
  .sr-only { position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0); }

  /* ── Shell ───────────────────────────────────── */
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 28px 56px;
  }

  /* ── Nav ─────────────────────────────────────── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 44px;
  }
  .brand {
    font-family: 'DM Serif Display', serif;
    font-size: 17px;
    color: var(--black);
    letter-spacing: -0.01em;
  }
  .brand span { color: var(--teal); }
  .label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--grey);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 4px;
  }

  /* ── Intro ───────────────────────────────────── */
  .intro { margin-bottom: 40px; }
  .kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--grey);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 400;
    color: var(--black);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  h1 em { color: var(--teal); font-style: italic; }
  .lead {
    font-size: 15px;
    color: var(--muted);
    max-width: 580px;
    line-height: 1.65;
  }

  /* ── Two-col ─────────────────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 48px;
    align-items: start;
  }
  @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }

  .panel {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    background: var(--white);
  }
  .panel-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 4px;
  }
  .panel-sub {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 14px;
    line-height: 1.55;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .btn-teal  { background: var(--teal); color: #fff; }
  .btn-teal:hover:not(:disabled) { opacity: 0.85; }
  .btn-outline {
    background: var(--white);
    color: var(--black);
    border: 1px solid var(--border);
  }
  .btn-outline:hover:not(:disabled) { border-color: #aaa; background: var(--soft); }
  .btn-outline.loading { color: var(--grey); }

  /* Form */
  #form { margin-bottom: 0; }
  input[type="email"] {
    width: 100%;
    padding: 9px 13px;
    border: 1px solid var(--border);
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: var(--black);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
    margin-bottom: 10px;
    display: block;
  }
  input[type="email"]::placeholder { color: #c0c0c0; }
  input[type="email"]:focus { border-color: var(--teal); }

  .date-input {
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 7px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: var(--black);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
  }
  .date-input:focus { border-color: var(--teal); }

  .status-msg {
    font-size: 12px;
    min-height: 18px;
    color: var(--grey);
    margin-top: 8px;
    line-height: 1.4;
  }
  .status-msg.ok  { color: var(--teal); }
  .status-msg.err { color: #c0392b; }
  .status-msg.info { color: var(--grey); }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 20px 0;
  }

  /* Spinner inside button */
  .spin {
    width: 12px; height: 12px;
    border: 2px solid rgba(0,0,0,0.15);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  .btn-teal .spin { border-color: rgba(255,255,255,0.3); border-top-color: #fff; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Subscriber list panel ────────────────────── */
  .list-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }
  .list-header .panel-label { margin-bottom: 2px; }
  .demo-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.05em;
    color: var(--coral);
    background: rgba(255,133,82,0.07);
    border: 1px solid rgba(255,133,82,0.2);
    border-radius: 3px;
    padding: 2px 7px;
    display: inline-block;
    margin-top: 4px;
  }
  .icon-btn {
    flex-shrink: 0;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--grey);
    padding: 6px 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: all 0.15s;
    margin-top: 2px;
  }
  .icon-btn:hover { border-color: var(--teal); color: var(--teal); }

  .sub-list {
    border: 1px solid var(--border);
    border-radius: 7px;
    overflow: hidden;
    min-height: 60px;
  }
  .sub-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    border-bottom: 1px solid var(--border);
    animation: fadeIn 0.2s ease;
  }
  .sub-row:last-child { border-bottom: none; }
  .sub-email {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: #bbb;
    white-space: nowrap;
  }
  .rm {
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: #ccc;
    padding: 3px 7px;
    border-radius: 4px;
    transition: all 0.15s;
    line-height: 1;
  }
  .rm:hover { color: #c0392b; background: #fff0ee; }

  .sub-empty {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #ccc;
    padding: 16px;
    text-align: center;
  }
  .sub-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #bbb;
    margin-top: 10px;
  }

  .loading-dots { display: flex; gap: 5px; justify-content: center; padding: 20px; }
  .loading-dots span {
    width: 5px; height: 5px;
    background: #e0e0e0;
    border-radius: 50%;
    animation: bounce 1.2s ease-in-out infinite;
  }
  .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .loading-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce { 0%,80%,100% { transform: scale(0.5); opacity: 0.3; } 40% { transform: scale(1); opacity: 1; } }
  @keyframes fadeIn  { from { opacity: 0; } to { opacity: 1; } }

  /* ── Pipeline ────────────────────────────────── */
  .pipeline-section {
    padding-top: 44px;
    border-top: 1px solid var(--border);
  }
  .pipeline-header {
    text-align: center;
    margin-bottom: 28px;
  }
  h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    color: var(--black);
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .pipeline {
    display: grid;
    grid-template-columns: 1fr 28px 1fr 28px 1fr;
    align-items: start;
    margin-bottom: 20px;
  }
  @media (max-width: 640px) {
    .pipeline { grid-template-columns: 1fr; }
    .arrow { display: none; }
  }
  .step {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    background: var(--white);
    text-align: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.03);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .step:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.05);
  }
  .step-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--grey);
    letter-spacing: 0.12em;
    margin-bottom: 8px;
  }
  .step-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 8px;
  }
  .step-body {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    text-align: left;
  }
  .arrow {
    display: flex;
    align-items: flex-start;
    padding-top: 26px;
    justify-content: center;
    color: #d0d0d0;
    font-size: 16px;
  }

  /* Chips */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 36px;
  }
  .chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--grey);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 14px;
    background: var(--soft);
  }
  .chip.teal {
    color: var(--teal);
    border-color: rgba(0, 108, 103, 0.2);
    background: rgba(0, 108, 103, 0.04);
  }

  /* ── Footer ──────────────────────────────────── */
  footer {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: space-between;
    font-size: 11px;
    color: #c0c0c0;
    font-family: 'JetBrains Mono', monospace;
  }
</style>

<script>
  const API = '';

  // ── Load subscriber list ──────────────────────
  async function loadSubs() {
    const list  = document.getElementById('list');
    const count = document.getElementById('count');
    try {
      const res  = await fetch(`${API}/phase3/subscribers`);
      if (!res.ok) throw new Error();
      const data = await res.json();
      if (!Array.isArray(data) || data.length === 0) {
        list.innerHTML    = '<div class="sub-empty">No subscribers yet.</div>';
        count.textContent = '';
      } else {
        list.innerHTML = data.map(s => `
          <div class="sub-row">
            <div class="sub-email" title="${esc(s.email)}">${esc(s.email)}</div>
            <div class="sub-date">${s.created_at ? new Date(s.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : ''}</div>
            <button class="rm" data-email="${encodeURIComponent(s.email)}" aria-label="Remove ${esc(s.email)}">remove</button>
          </div>`).join('');
        count.textContent = `${data.length} active subscriber${data.length === 1 ? '' : 's'}`;
      }
    } catch {
      list.innerHTML = '<div class="sub-empty">Cannot reach server.</div>';
    }
  }

  // ── Subscribe form ────────────────────────────
  document.getElementById('form').addEventListener('submit', async e => {
    e.preventDefault();
    const input  = document.getElementById('email');
    const btn    = document.getElementById('sub-btn');
    const status = document.getElementById('sub-status');
    const email  = input.value.trim();

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      status.className = 'status-msg err';
      status.textContent = 'Please enter a valid email address.';
      return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spin"></span> Subscribing…';
    status.className = 'status-msg';
    status.textContent = '';

    try {
      const res = await fetch(`${API}/phase3/subscribe`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email }),
      });
      if (res.ok) {
        status.className = 'status-msg ok';
        status.textContent = `Subscribed — ${esc(email)}`;
        input.value = '';
        await loadSubs();
      } else {
        const err = await res.json().catch(() => ({}));
        status.className = 'status-msg err';
        status.textContent = err.detail || 'Something went wrong.';
      }
    } catch {
      status.className = 'status-msg err';
      status.textContent = 'Network error — is the server running?';
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Subscribe';
    }
  });

  // ── Remove subscriber ─────────────────────────
  document.getElementById('list').addEventListener('click', async e => {
    const btn = e.target.closest('.rm');
    if (!btn) return;
    const email = decodeURIComponent(btn.dataset.email);
    if (!confirm(`Remove ${email} from the mailing list?`)) return;
    btn.textContent = '…';
    btn.disabled = true;
    try {
      const res = await fetch(`${API}/phase3/unsubscribe`, {
        method:  'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email }),
      });
      if (res.ok) { await loadSubs(); }
      else { btn.textContent = 'remove'; btn.disabled = false; }
    } catch {
      btn.textContent = 'remove';
      btn.disabled = false;
    }
  });

  // ── Run pipeline ──────────────────────────────
  document.getElementById('run-btn').addEventListener('click', async () => {
    const btn    = document.getElementById('run-btn');
    const status = document.getElementById('run-status');
    const dateInput = document.getElementById('run-date');
    let runDate = dateInput.value;
    
    if (!runDate) {
      runDate = new Date().toISOString().slice(0, 10);
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spin"></span> Running…';
    status.className = 'status-msg info';
    status.textContent = `Pipeline started for ${runDate} — this can take a few minutes.`;

    try {
      const res   = await fetch(`${API}/run?date=${runDate}`, { method: 'POST' });
      const data  = await res.json().catch(() => ({}));

      if (res.ok) {
        const p2 = data.phase2 || {};
        status.className = 'status-msg ok';
        status.textContent = `Done — ${data.phase1_confirmed ?? 0} relevant docs found, ${p2.processed ?? 0} summarised. Digest ${data.digest_built ? 'sent.' : 'not sent (no docs).'}`;
        await loadSubs();
      } else {
        status.className = 'status-msg err';
        status.textContent = data.detail || 'Pipeline returned an error.';
      }
    } catch {
      status.className = 'status-msg err';
      status.textContent = 'Network error — is the server running?';
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Send digest';
    }
  });

  // ── Init ──────────────────────────────────────
  document.getElementById('refresh').addEventListener('click', loadSubs);
  document.getElementById('run-date').value = new Date().toISOString().slice(0, 10);

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  loadSubs();
</script>
