<!-- ======================================================= -->
<!-- CLIENT SCRIPT                                            -->
<!-- ======================================================= -->
<script>
  const API = 'http://localhost:8000';

  // ── Load subscribers ──────────────────────────────────────
  async function loadSubscribers() {
    const list = document.getElementById('subscribers-list');
    const count = document.getElementById('subscribers-count');
    try {
      const res = await fetch(`${API}/phase3/subscribers`);
      if (!res.ok) throw new Error('Failed');
      const subscribers = await res.json();
      if (subscribers.length === 0) {
        list.innerHTML = '<div class="empty-state mono">No active subscribers yet.</div>';
        count.textContent = '';
      } else {
        list.innerHTML = subscribers.map(s => `
          <div class="subscriber-item" data-email="${encodeURIComponent(s.email)}">
            <div>
              <div class="subscriber-email">${escHtml(s.email)}</div>
              <div class="subscriber-date">${s.created_at ? new Date(s.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) : ''}</div>
            </div>
            <button class="remove-btn" data-email="${encodeURIComponent(s.email)}" title="Remove subscriber" aria-label="Remove ${escHtml(s.email)}">✕</button>
          </div>
        `).join('');
        count.textContent = `${subscribers.length} active subscriber${subscribers.length === 1 ? '' : 's'}`;
      }
    } catch {
      list.innerHTML = '<div class="empty-state mono" style="color:#555">Couldn\'t reach server.</div>';
    }
  }

  // ── Subscribe form ────────────────────────────────────────
  document.getElementById('subscribe-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('email-input') as HTMLInputElement;
    const btn = document.getElementById('subscribe-btn') as HTMLButtonElement;
    const btnText = document.getElementById('subscribe-btn-text');
    const btnSpinner = document.getElementById('subscribe-btn-spinner');
    const email = input.value.trim();

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showStatus('error', 'Please enter a valid email address.');
      return;
    }

    btn.disabled = true;
    btnText && (btnText.hidden = true);
    btnSpinner && (btnSpinner.hidden = false);
    showStatus('', '');

    try {
      const res = await fetch(`${API}/phase3/subscribe`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (!res.ok) {
        const err = await res.json();
        showStatus('error', err.detail || 'Server error. Try again.');
      } else {
        showStatus('success', `<strong>${escHtml(email)}</strong> subscribed! The daily digest will arrive each morning.`);
        input.value = '';
        await loadSubscribers();
      }
    } catch {
      showStatus('error', 'Network error. Make sure the server is running.');
    } finally {
      btn.disabled = false;
      btnText && (btnText.hidden = false);
      btnSpinner && (btnSpinner.hidden = true);
    }
  });

  // ── Remove subscriber (delegated) ────────────────────────
  document.getElementById('subscribers-list')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.remove-btn') as HTMLElement | null;
    if (!btn) return;
    const email = decodeURIComponent(btn.dataset.email || '');
    if (!email) return;
    if (!confirm(`Remove ${email} from the mailing list?`)) return;

    btn.disabled = true;
    btn.textContent = '…';

    try {
      const res = await fetch(`${API}/phase3/unsubscribe`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (!res.ok) {
        alert('Failed to remove subscriber.');
        btn.disabled = false;
        btn.textContent = '✕';
      } else {
        await loadSubscribers();
      }
    } catch {
      alert('Network error.');
      btn.disabled = false;
      btn.textContent = '✕';
    }
  });

  // ── Refresh button ────────────────────────────────────────
  document.getElementById('refresh-btn')?.addEventListener('click', loadSubscribers);

  // ── Helpers ───────────────────────────────────────────────
  function showStatus(type, html) {
    const el = document.getElementById('subscribe-status');
    el.className = 'form-status ' + type;
    el.innerHTML = html;
  }

  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Init ──────────────────────────────────────────────────
  loadSubscribers();
</script>
