OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase REST API (if Phase 1/2 uses it)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# Postgres Connection String (Required for Phase 3 SQLAlchemy)
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=your_postgresql_connection_string_here

# Inter-phase service URLs
PHASE1_RUN_URL=http://localhost:8001/phase1/run
PHASE2_RUN_URL=http://localhost:8002/phase2/run
PHASE2_CORRECTION_URL=http://localhost:8002/phase2/correct
PHASE3_INGEST_URL=http://localhost:8003/phase3/ingest

# SMTP Test Mailer (Dev only — used by POST /phase3/mail/test)
# Gmail: set SMTP_HOST=smtp.gmail.com, SMTP_PORT=465
# Use a Gmail App Password (not your account password):
#   myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16char_app_password_here
SMTP_FROM=Open Paws Sentinel <your_gmail_address@gmail.com>
