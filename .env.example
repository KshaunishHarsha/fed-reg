OPENROUTER_API_KEY=your_openrouter_api_key_here

# Postgres Connection String (all phases)
# Railway format:  postgresql://postgres:[password]@[host]:5432/railway
# asyncpg format:  postgresql+asyncpg://postgres:[password]@[host]:5432/railway
DATABASE_URL=your_postgresql_connection_string_here

# (No inter-phase URLs needed — all phases run in the same process via main.py)

# SMTP Test Mailer (Dev only — used by POST /phase3/mail/test)
# Gmail: set SMTP_HOST=smtp.gmail.com, SMTP_PORT=465
# Use a Gmail App Password (not your account password):
#   myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16char_app_password_here
SMTP_FROM=Open Paws Sentinel <your_gmail_address@gmail.com>

DEMO=true

# CORS — comma-separated list of allowed origins
# Dev: include the Astro dev server
# Production: replace with your Vercel URL
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000

# Frontend login password (Astro PUBLIC_ prefix required for client-side access)
# Set this in Vercel environment variables for production
# Leave empty to disable the login gate entirely
PUBLIC_PASSWORD=your_demo_password_here

# Railway backend URL — used by the Astro frontend to call the API
# Dev: leave empty (Vite proxy handles it). Production: set to your Railway URL.
PUBLIC_API_URL=https://your-railway-app.up.railway.app

# Astro frontend URL — used by the backend to build "Draft a Comment" deep-links
# in Section A email cards. Leave empty to hide the button.
FRONTEND_URL=https://your-vercel-app.vercel.app